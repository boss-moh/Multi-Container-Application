{
  "name": "multi-container-application",
  "version": "1.0.0",
  "description": "A multi-container application using Node.js and Express",
  "main": "index.js",
  "scripts": {
    "test": "jest ",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "dev": "ts-node-dev --respawn --env-file=.env  --require tsconfig-paths/register src/server.ts ",
    "build": "tsc  && tsc-alias ",
    "start": "node --env-file=.env  dist/server.js",
    "seed": "ts-node-dev --respawn --env-file=.env --require tsconfig-paths/register src/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boss-moh/Multi-Container-Application.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/boss-moh/Multi-Container-Application/issues"
  },
  "homepage": "https://github.com/boss-moh/Multi-Container-Application#readme",
  "dependencies": {
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "mongoose": "^9.2.1",
    "tsc-alias": "^1.8.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
